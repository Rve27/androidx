- description: Initial State
  command: Capture
  result:
    type: CoreDocument
    width: 1000
    height: 1000
    operations:
    - type: RootLayoutComponent
      id: -2
      x: 0.0
      y: 0.0
      width: 1000.0
      height: 1000.0
      visibility: VISIBLE
      list:
      - type: ROW
        id: -3
        x: 0.0
        y: 0.0
        width: 1000.0
        height: 1000.0
        visibility: VISIBLE
        list:
        - type: ComponentModifiers
          modifiers:
          - type: WidthModifierOperation
            width: {type: Variable, id: 0, value: !!float 'NaN'}
            dimensionModifierType: FILL
          - type: HeightModifierOperation
            height: {type: Variable, id: 0, value: !!float 'NaN'}
            dimensionModifierType: FILL
          - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 1000.0, height: 1000.0,
            color: '0xffffff00', shapeType: RECTANGLE}
        - type: BOX
          id: 2
          x: 0.0
          y: 0.0
          width: 100.0
          height: 400.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - type: DimensionConstraintsModifierOperation
              constraints: REQUIRED_VERTICAL
              min: {type: Value, value: 400.0}
              max: {type: Value, value: 500.0}
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 100.0, height: 400.0,
              color: '0xffff0000', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        - type: BOX
          id: 3
          x: 100.0
          y: 0.0
          width: 100.0
          height: 500.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 800.0}
              dimensionModifierType: EXACT
            - type: DimensionConstraintsModifierOperation
              constraints: REQUIRED_VERTICAL
              min: {type: Value, value: 400.0}
              max: {type: Value, value: 500.0}
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 100.0, height: 500.0,
              color: '0xff00ff00', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        paddingLeft: 0.0
        paddingRight: 0.0
        paddingTop: 0.0
        paddingBottom: 0.0
        verticalPositioning: TOP
        horizontalPositioning: START
        spacedBy: 0.0
