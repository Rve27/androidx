- description: Initial State
  command: Capture
  result:
    type: CoreDocument
    width: 1000
    height: 1000
    operations:
    - type: RootLayoutComponent
      id: -2
      x: 0.0
      y: 0.0
      width: 1000.0
      height: 1000.0
      visibility: VISIBLE
      list:
      - type: BOX
        id: -3
        x: 0.0
        y: 0.0
        width: 100.0
        height: 100.0
        visibility: VISIBLE
        list:
        - type: ComponentModifiers
          modifiers:
          - type: WidthModifierOperation
            width: {type: Value, value: 100.0}
            dimensionModifierType: EXACT
          - type: HeightModifierOperation
            height: {type: Value, value: 100.0}
            dimensionModifierType: EXACT
        - type: BOX
          id: -5
          x: 0.0
          y: 0.0
          width: 50.0
          height: 50.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 50.0, height: 50.0,
              color: '0xff00ff00', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        paddingLeft: 0.0
        paddingRight: 0.0
        paddingTop: 0.0
        paddingBottom: 0.0
        verticalPositioning: TOP
        horizontalPositioning: START
