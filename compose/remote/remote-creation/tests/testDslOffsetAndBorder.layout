- description: Initial State
  command: Capture
  result:
    type: CoreDocument
    width: 400
    height: 400
    operations:
    - type: RootLayoutComponent
      id: -2
      x: 0.0
      y: 0.0
      width: 400.0
      height: 400.0
      visibility: VISIBLE
      list:
      - type: ROW
        id: 1
        x: 0.0
        y: 0.0
        width: 400.0
        height: 400.0
        visibility: VISIBLE
        list:
        - type: ComponentModifiers
          modifiers:
          - type: WidthModifierOperation
            width: {type: Variable, id: 0, value: !!float 'NaN'}
            dimensionModifierType: FILL
          - type: HeightModifierOperation
            height: {type: Variable, id: 0, value: !!float 'NaN'}
            dimensionModifierType: FILL
          - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 400.0, height: 400.0,
            color: '0xffffffff', shapeType: RECTANGLE}
        - type: BOX
          id: 2
          x: 0.0
          y: 0.0
          width: 100.0
          height: 100.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 100.0, height: 100.0,
              color: '0xff00ff00', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: TOP
          horizontalPositioning: START
        - type: BOX
          id: 3
          x: 100.0
          y: 0.0
          width: 100.0
          height: 100.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - {type: OffsetModifierOperation, x: 50.0, y: 50.0}
            - type: WidthModifierOperation
              width: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 100.0, height: 100.0,
              color: '0xffff0000', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: TOP
          horizontalPositioning: START
        - type: BOX
          id: 4
          x: 200.0
          y: 0.0
          width: 100.0
          height: 100.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 100.0, height: 100.0,
              color: '0xff0000ff', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: TOP
          horizontalPositioning: START
        paddingLeft: 0.0
        paddingRight: 0.0
        paddingTop: 0.0
        paddingBottom: 0.0
        verticalPositioning: TOP
        horizontalPositioning: START
        spacedBy: 0.0
