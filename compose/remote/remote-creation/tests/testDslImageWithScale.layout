- description: Initial State
  command: Capture
  result:
    type: CoreDocument
    width: 900
    height: 300
    operations:
    - type: RootLayoutComponent
      id: -2
      x: 0.0
      y: 0.0
      width: 900.0
      height: 300.0
      visibility: VISIBLE
      list:
      - {type: BitmapData, imageId: 42, imageWidth: 200, imageHeight: 100, imageType: TYPE_RAW8888,
        encoding: ENCODING_INVALID}
      - type: ROW
        id: 10
        x: 0.0
        y: 0.0
        width: 900.0
        height: 300.0
        visibility: VISIBLE
        list:
        - type: ComponentModifiers
          modifiers:
          - type: WidthModifierOperation
            width: {type: Variable, id: 0, value: !!float 'NaN'}
            dimensionModifierType: FILL
          - type: HeightModifierOperation
            height: {type: Variable, id: 0, value: !!float 'NaN'}
            dimensionModifierType: FILL
          - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 900.0, height: 300.0,
            color: '0xffffffff', shapeType: RECTANGLE}
        - type: IMAGE_LAYOUT
          id: 11
          x: 0.0
          y: 0.0
          width: 300.0
          height: 300.0
          visibility: VISIBLE
          list:
