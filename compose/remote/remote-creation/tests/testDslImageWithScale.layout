              width: {type: Value, value: 300.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 300.0}
              dimensionModifierType: EXACT
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
        - type: IMAGE_LAYOUT
          id: 13
          x: 600.0
          y: 0.0
          width: 300.0
          height: 300.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
