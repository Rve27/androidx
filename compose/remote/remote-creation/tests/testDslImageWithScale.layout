              dimensionModifierType: EXACT
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
        - type: IMAGE_LAYOUT
          id: 12
          x: 300.0
          y: 0.0
          width: 300.0
          height: 300.0
          visibility: VISIBLE
