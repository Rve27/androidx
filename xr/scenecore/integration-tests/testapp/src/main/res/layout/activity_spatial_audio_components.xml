<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".spatialaudio.SpatialAudioComponentsActivity">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_spatial_audio_test"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/arrow_back"
            app:navigationIconTint="@color/white"
            android:background="@color/google_blue"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/cardViewSoundEffectPool"
            app:titleCentered="true"
            app:title="@string/cuj_spatial_audio_test" />

        <!-- First Card: SoundEffectPoolComponent -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardViewSoundEffectPool"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar_spatial_audio_test">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SoundEffectPoolComponent"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/button_sound_effect_pool_play"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/test_button"
                        android:layout_weight="1"
                        android:textSize="18sp"
                        android:text="Play Sound Effect"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/button_sound_effect_pool_play_corrupt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/test_button"
                        android:layout_weight="1"
                        android:textSize="18sp"
                        android:text="Play Corrupt Sound"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Second Card: PositionalAudioComponent -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardViewPositionalAudio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardViewSoundEffectPool">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PositionalAudioComponent"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/text_positional_audio_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status: Detached"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">
                        <Button
                            android:id="@+id/button_positional_audio_play_tiger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/test_button"
                            android:layout_weight="1"
                            android:textSize="18sp"
                            android:text="Play Tiger (Raw)"
                            android:layout_marginEnd="8dp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/button_positional_audio_toggle_attachment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/test_button"
                        android:textSize="18sp"
                        android:text="Attach to sound panel"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Third Card: SoundFieldAudioComponent (First Order) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardViewSoundFieldFirstOrder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardViewPositionalAudio">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SoundFieldAudioComponent (1st Order)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/button_sound_field_play_wav"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/test_button"
                    android:textSize="18sp"
                    android:text="Play Basketball (WAV)"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fourth Card: SoundFieldAudioComponent (Third Order) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardViewSoundFieldThirdOrder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardViewSoundFieldFirstOrder">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SoundFieldAudioComponent (3rd Order)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/button_sound_field_play_opus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/test_button"
                    android:textSize="18sp"
                    android:text="Play Dunes (OPUS)"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/bottomCenterFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:contentDescription="Restart Activity"
            android:scaleX="1.25"
            android:scaleY="1.25"
            android:backgroundTint="@color/google_blue"
            android:src="@drawable/recreate"
            app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
